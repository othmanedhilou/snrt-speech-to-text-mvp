# ── Copy this file to .env and fill in your values ───────────────────────────

# Groq API — free tier, get key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Whisper model: tiny | small | medium | large-v3
# Use "small" on Oracle Cloud free (4 CPU, 24GB RAM)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Capture chunk duration in seconds
CHUNK_DURATION=30

# Max parallel channels
MAX_WORKERS=3

# SNRT channel stream URLs — add the real m3u8 / RTSP URLs
AL_AOULA_URL=
ARRYADIA_URL=
ASSADISSA_URL=
ARRABIA_URL=
AMAZIGHIE_URL=

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_REFRESH=20
